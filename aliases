# rwtc = rx worktree create (explicit rx-frontend, ignores current directory)
rwtc() {
  if [ -z "$1" ]; then
    echo "Usage: rwtc <worktree-name>" >&2
    return 1
  fi
  local name="$1"
  local wt_path="$HOME/Code/rx-frontend-wt/$name"

  # Create worktree if it doesn't exist (in subshell to preserve cwd)
  local needs_setup=false
  if [ ! -d "$wt_path" ]; then
    (cd ~/Code/rx-frontend-wt && git fetch origin main && git worktree add "$name" -b "ben/$name" origin/main && cd "$name" && ../setup-worktree.sh --skip-install)
    needs_setup=true
  fi

  # Create new tmux window with split panes
  tmux new-window -n "$name" -c "$wt_path"
  tmux set-window-option automatic-rename off
  tmux split-window -h -c "$wt_path"
  # Run npm install in the right pane if needed
  if $needs_setup; then
    tmux send-keys "npm install" Enter
  fi
  tmux select-pane -L
  tmux send-keys "claude --permission-mode plan; tcc" Enter
}

# wtc = worktree create (new tmux window with split panes + Claude)
# Auto-detects repo from current directory (rx-frontend-wt or ap-ui-wt)
wtc() {
  if [ -z "$1" ]; then
    echo "Usage: wtc <worktree-name>" >&2
    return 1
  fi
  local name="$1"
  local base_path
  local run_setup=false

  # Detect repo from current directory
  case "$(pwd)" in
    *ap-ui*)
      base_path="$HOME/Code/ap-ui-wt"
      ;;
    *rx-frontend*)
      base_path="$HOME/Code/rx-frontend-wt"
      run_setup=true
      ;;
    *)
      echo "Could not detect repo from current directory (use from ap-ui-wt or rx-frontend-wt)" >&2
      return 1
      ;;
  esac

  local wt_path="$base_path/$name"

  # Create worktree if it doesn't exist (in subshell to preserve cwd)
  local needs_setup=false
  if [ ! -d "$wt_path" ]; then
    if $run_setup; then
      (cd "$base_path" && git fetch origin main && git worktree add "$name" -b "ben/$name" origin/main && cd "$name" && ../setup-worktree.sh --skip-install)
      needs_setup=true
    else
      (cd "$base_path" && git fetch origin main && git worktree add "$name" -b "ben/$name" origin/main)
    fi
  fi

  # Create new tmux window with split panes
  tmux new-window -n "$name" -c "$wt_path"
  tmux set-window-option automatic-rename off  # Prevent tmux from overwriting window name
  tmux split-window -h -c "$wt_path"
  # Run npm install in the right pane if needed (runs visibly in background)
  if $needs_setup; then
    tmux send-keys "npm install" Enter
  fi
  tmux select-pane -L
  # Run claude, then clear red dot when it exits
  tmux send-keys "claude --permission-mode plan; tcc" Enter
}

# wtcs = worktree create split (same as wtc but splits current window instead of new one)
wtcs() {
  if [ -z "$1" ]; then
    echo "Usage: wtcs <worktree-name>" >&2
    return 1
  fi
  local name="$1"
  local base_path
  local run_setup=false

  # Detect repo from current directory
  case "$(pwd)" in
    *ap-ui*)
      base_path="$HOME/Code/ap-ui-wt"
      ;;
    *rx-frontend*)
      base_path="$HOME/Code/rx-frontend-wt"
      run_setup=true
      ;;
    *)
      echo "Could not detect repo from current directory (use from ap-ui-wt or rx-frontend-wt)" >&2
      return 1
      ;;
  esac

  local wt_path="$base_path/$name"

  # Create worktree if it doesn't exist (in subshell to preserve cwd)
  local needs_setup=false
  if [ ! -d "$wt_path" ]; then
    if $run_setup; then
      (cd "$base_path" && git fetch origin main && git worktree add "$name" -b "ben/$name" origin/main && cd "$name" && ../setup-worktree.sh --skip-install)
      needs_setup=true
    else
      (cd "$base_path" && git fetch origin main && git worktree add "$name" -b "ben/$name" origin/main)
    fi
  fi

  # Run npm install in background if needed (wtcs has no spare pane)
  if $needs_setup; then
    (cd "$wt_path" && npm install &> /tmp/npm-install-$name.log &)
    echo "npm install running in background (log: /tmp/npm-install-$name.log)"
  fi

  # Split current pane vertically (side by side) and run claude there
  tmux split-window -h -c "$wt_path"
  tmux send-keys "claude --permission-mode plan; tcc" Enter
}

